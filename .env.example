# LocalCut Environment Configuration

# Server
PORT=9470
HOST=localhost

# AI Server
AI_SERVER_PORT=9471
AI_SERVER_HOST=localhost

# FFmpeg path (leave empty if in system PATH)
FFMPEG_PATH=
FFPROBE_PATH=

# Default project storage directory
PROJECTS_DIR=~/LocalCut-Projects

# Proxy generation settings
PROXY_ENABLED=true
PROXY_RESOLUTION=960x540
PROXY_CODEC=libx264
PROXY_CRF=23

# AI Model settings
# GPU device index (-1 for CPU)
GPU_DEVICE=0
# Maximum GPU memory usage in MB (0 = unlimited)
MAX_GPU_MEMORY=0
